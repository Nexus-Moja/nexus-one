    "livecare:test": "node scripts/livecare-test.mjs",
    "ai:test": "node scripts/ai-operations-test.mjs",
    "executive:test": "node scripts/executive-test.mjs",
    "foundation:test": "node scripts/production-foundation-test.mjs",
