  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "framer-motion": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "stripe": "^22.3.2",
    "typescript": "latest",
    "vite": "latest"
  },
  "description": "NEXUS ONE Healthcare Mobility Platform with LiveCare and operational modules"
