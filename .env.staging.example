APP_ENV=staging
NODE_ENV=production
APP_NAME=NEXUS ONE Staging
APP_ORIGIN=https://staging.nexusmt.com
HOST=0.0.0.0
PORT=4173
LOG_LEVEL=info
DATABASE_PROVIDER=postgres
DB_PATH=/app/data/nexus-one-staging.sqlite
SESSION_SECRET=replace-with-at-least-32-random-characters
ADMIN_KEY=replace-with-at-least-24-random-characters
ENABLE_PREVIEW_ACCOUNTS=false
ENABLE_MOCK_FLEET=false
ENABLE_PAYMENTS=false
ENABLE_NOTIFICATIONS=false
GOOGLE_MAPS_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SENTRY_DSN=
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
DB_SSL=true
DB_POOL_MAX=10
